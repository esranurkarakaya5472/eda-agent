# ──────────────────────────────────────────────────────────────────────────────
# EDA Agent — .gitignore
# ──────────────────────────────────────────────────────────────────────────────

# ── Secrets & Environment (CRITICAL: never commit these!) ────────────────────
.env
.env.local
.env.*.local

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# ── Virtual Environments ─────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/
.conda/

# ── Streamlit ────────────────────────────────────────────────────────────────
.streamlit/secrets.toml

# ── Data & Generated Files (keep samples only) ───────────────────────────────
incoming/*.csv
processed/*.csv
reports/*.html
reports/*.md
reports/*.json

# ── Jupyter Notebooks ────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── IDE & Editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Logs & Temporary Files ───────────────────────────────────────────────────
*.log
*.tmp
*.bak
tmp/
temp/

# ── OS Generated ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini
